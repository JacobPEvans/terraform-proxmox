{
  "_comment": "Non-secret deployment config. Committed to git, plain JSON, readable in PRs. Edit directly—no SOPS needed. Network topology (network_prefix, SSH paths) is in terraform.sops.json. See docs/SOPS_SETUP.md.",

  "proxmox_node": "pve",
  "environment": "homelab",
  "proxmox_iso_debian": "debian-13.2.0-amd64-netinst.iso",
  "proxmox_ct_template_debian": "debian-13-standard_13.1-2_amd64.tar.zst",
  "ansible_cloud_init_file": "cloud-init/ansible-server-example.yml",

  "splunk_vm_id": 200,
  "splunk_vm_name": "splunk-aio",
  "splunk_vm_pool_id": "logging",
  "template_id": 9200,
  "splunk_boot_disk_size": 25,
  "splunk_data_disk_size": 200,

  "pools": {
    "logging": { "comment": "Logging and observability infrastructure" },
    "ai": { "comment": "AI development environments" },
    "infrastructure": { "comment": "Core infrastructure services" }
  },

  "datastores": {},

  "host_services": {
    "nas": {
      "zfs_dataset": "rpool/data/nas",
      "zfs_quota": "1T",
      "mount_point": "/mnt/nas",
      "smb_share_name": "nas",
      "directories": ["huggingface/hub", "ollama/models", "media", "backups"],
      "description": "Host-level NAS: ZFS dataset on local-zfs served via Samba. Managed by ansible-proxmox."
    }
  },

  "vms": {
    "docker-host": {
      "vm_id": 250,
      "name": "docker",
      "description": "Docker Swarm host - Cribl Edge and Stream services",
      "cpu_cores": 4,
      "memory_dedicated": 8192,
      "tags": ["terraform", "cribl", "docker", "logging", "swarm"],
      "pool_id": "logging",
      "boot_disk": { "datastore_id": "local-zfs", "size": 50 },
      "additional_disks": [{ "datastore_id": "local-zfs", "interface": "scsi1", "size": 100 }],
      "clone_template": { "template_id": 9000 },
      "user_account": { "username": "debian", "password": "", "keys": [] }
    }
  },

  "containers": {
    "ansible": {
      "vm_id": 100,
      "hostname": "ansible",
      "description": "Ansible control node - primary",
      "cpu_cores": 2,
      "memory_dedicated": 2048,
      "memory_swap": 6144,
      "tags": ["terraform", "ansible", "control-plane", "container"],
      "pool_id": "infrastructure",
