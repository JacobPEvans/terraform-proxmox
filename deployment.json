{
  "_comment": "Non-secret deployment config. Committed to git, plain JSON, readable in PRs. Edit directly—no SOPS needed. Network topology (network_prefix, SSH paths) is in terraform.sops.json. See docs/SOPS_SETUP.md.",

  "proxmox_node": "pve",
  "environment": "homelab",
  "domain": "jacobpevans.com",

  "proxmox_iso_debian": "debian-13.2.0-amd64-netinst.iso",
  "proxmox_ct_template_debian": "debian-13-standard_13.1-2_amd64.tar.zst",
  "ansible_cloud_init_file": "cloud-init/ansible-server-example.yml",

  "splunk_vm_id": 200,
  "splunk_vm_name": "splunk-aio",
  "splunk_vm_pool_id": "logging",
  "template_id": 9200,
  "splunk_boot_disk_size": 25,
  "splunk_data_disk_size": 200,

  "pools": {
    "logging": { "comment": "Logging and observability infrastructure" },
    "ai": { "comment": "AI development environments" },
    "infrastructure": { "comment": "Core infrastructure services" }
  },

  "datastores": {},

  "host_services": {
    "nas": {
      "zfs_dataset": "rpool/data/nas",
      "zfs_quota": "1T",
      "mount_point": "/mnt/nas",
      "smb_share_name": "nas",
      "directories": ["huggingface/hub", "ollama/models", "media", "backups"],
      "description": "Host-level NAS: ZFS dataset on local-zfs served via Samba. Managed by ansible-proxmox."
    }
  },

  "vms": {},

  "containers": {
    "ansible": {
      "vm_id": 100,
      "hostname": "ansible",
      "description": "Ansible control node - primary",
      "cpu_cores": 2,
      "memory_dedicated": 2048,
      "memory_swap": 512,
      "tags": ["terraform", "ansible", "control-plane", "container"],
      "pool_id": "infrastructure",
      "root_disk": { "size": 64 }
    },
    "mssql": {
      "vm_id": 130,
      "hostname": "mssql",
      "description": "Microsoft SQL Server 2022 - Docker in LXC",
      "cpu_cores": 4,
      "memory_dedicated": 4096,
      "memory_swap": 2048,
      "tags": ["terraform", "container", "database", "docker"],
      "pool_id": "infrastructure",
      "root_disk": { "size": 16 },
      "mount_points": [
        { "volume": "local-zfs", "size": "50G", "path": "/opt/mssql" }
      ],
      "features": { "nesting": true, "keyctl": true, "fuse": true }
    },
    "mailpit": {
      "vm_id": 110,
      "hostname": "mailpit",
      "description": "Mailpit SMTP relay with web UI - Docker in LXC",
      "cpu_cores": 1,
      "memory_dedicated": 512,
      "memory_swap": 256,
      "tags": ["terraform", "container", "notifications", "smtp", "docker"],
      "pool_id": "infrastructure",
      "root_disk": { "size": 8 },
      "features": { "nesting": true, "keyctl": true, "fuse": true }
    },
    "ntfy": {
      "vm_id": 111,
      "hostname": "ntfy",
      "description": "ntfy push notification server - Docker in LXC",
      "cpu_cores": 1,
      "memory_dedicated": 512,
      "memory_swap": 256,
      "tags": ["terraform", "container", "notifications", "push", "docker"],
      "pool_id": "infrastructure",
      "root_disk": { "size": 8 },
      "features": { "nesting": true, "keyctl": true, "fuse": true }
    },
    "apt-cacher-ng": {
      "vm_id": 106,
      "hostname": "apt-cacher-ng",
      "description": "apt-cacher-ng - APT package caching proxy",
      "cpu_cores": 1,
      "memory_dedicated": 512,
      "memory_swap": 512,
      "tags": ["terraform", "container", "infrastructure", "apt-cache"],
      "pool_id": "infrastructure",
      "root_disk": { "size": 16 }
    },
    "qdrant": {
      "vm_id": 165,
      "hostname": "qdrant",
      "description": "Qdrant vector database - AI RAG memory store (Docker in LXC)",
      "cpu_cores": 2,
      "memory_dedicated": 8192,
      "memory_swap": 4096,
      "tags": ["terraform", "container", "vectordb", "ai", "docker"],
      "pool_id": "ai",
      "root_disk": { "size": 8 },
      "mount_points": [
        { "volume": "local-zfs", "size": "100G", "path": "/opt/qdrant" }
      ],
      "features": { "nesting": true, "keyctl": true, "fuse": true }
    },
    "haproxy": {
      "vm_id": 175,
      "hostname": "haproxy",
      "description": "HAProxy - syslog/NetFlow TCP+UDP load balancer",
      "cpu_cores": 2,
      "memory_dedicated": 1024,
      "memory_swap": 512,
      "tags": ["terraform", "container", "haproxy", "pipeline", "infrastructure"],
      "pool_id": "logging",
      "root_disk": { "size": 8 }
    },
    "cribl-stream": {
      "vm_id": 171,
      "hostname": "cribl-stream",
      "description": "Cribl Stream - log routing and transformation",
      "cpu_cores": 4,
      "memory_dedicated": 4096,
      "memory_swap": 2048,
      "tags": ["terraform", "container", "cribl", "stream", "pipeline", "logging"],
      "pool_id": "logging",
      "root_disk": { "size": 16 },
      "features": { "nesting": true, "keyctl": true, "fuse": true }
    },
    "cribl-edge-01": {
      "vm_id": 180,
      "hostname": "cribl-edge-01",
      "description": "Cribl Edge node 1 - syslog/NetFlow collection",
      "cpu_cores": 2,
      "memory_dedicated": 2048,
      "memory_swap": 1024,
      "tags": ["terraform", "container", "cribl", "edge", "pipeline", "logging"],
      "pool_id": "logging",
      "root_disk": { "size": 32 },
      "features": { "nesting": true, "keyctl": true, "fuse": true }
    },
    "cribl-edge-02": {
      "vm_id": 181,
      "hostname": "cribl-edge-02",
      "description": "Cribl Edge node 2 - syslog/NetFlow collection",
      "cpu_cores": 2,
      "memory_dedicated": 2048,
      "memory_swap": 1024,
      "tags": ["terraform", "container", "cribl", "edge", "pipeline", "logging"],
      "pool_id": "logging",
      "root_disk": { "size": 32 },
      "features": { "nesting": true, "keyctl": true, "fuse": true }
    }
  }
}
